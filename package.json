{
  "name": "juanbertos-pos",
  "version": "1.0.0",
  "description": "POS System for Juanbertos California Burritos",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "seed": "node server/seed.js",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "build:ios": "vite build --mode ios && npx cap sync"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "@stripe/stripe-js": "^2.4.0",
    "cors": "^2.8.5",
    "dexie": "^4.3.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "i18next": "^25.8.11",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.564.0",
    "qrcode.react": "^4.2.0",
    "react-i18next": "^16.5.4",
    "sql.js": "^1.10.0",
    "stripe": "^14.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.5.0",
    "@capacitor/ios": "^8.1.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
