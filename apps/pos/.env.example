# Stripe API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Server
PORT=3001
NODE_ENV=development

# Database (Neon Postgres)
DATABASE_URL=postgresql://neondb_owner:PASSWORD@HOST/neondb?sslmode=require
PG_APP_USER=app_user
PG_APP_PASSWORD=your_app_user_password

# AI Intelligence Layer (optional - heuristics work without this)
XAI_API_KEY=your_xai_api_key_here

# NOWPayments Crypto Payments (optional - enables crypto checkout)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret_here
NOWPAYMENTS_IPN_URL=https://your-domain.com/api/payments/crypto/ipn
NOWPAYMENTS_SANDBOX=true

# Twilio SMS (optional — enables loyalty SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Multi-tenancy
ADMIN_SECRET=your_admin_secret_here       # Protects /admin/* API routes
DEFAULT_TENANT_ID=                         # Optional fallback tenant for local dev
JWT_SECRET=your_jwt_secret_here           # JWT signing secret for owner auth

# Stripe Billing (SaaS subscription plans)
STRIPE_PRICE_STARTER=price_xxx            # Stripe Price ID for Starter plan ($29/mo)
STRIPE_PRICE_PRO=price_xxx                # Stripe Price ID for Pro plan ($79/mo)
STRIPE_PRICE_GHOST_KITCHEN=price_xxx      # Stripe Price ID for Ghost Kitchen plan ($129/mo)
# STRIPE_WEBHOOK_SECRET=whsec_xxx         # Stripe webhook endpoint signing secret
# APP_URL=https://pos.desktop.kitchen     # Base URL for Stripe redirect URLs

# CFDI Electronic Invoicing (optional — enables Mexican e-invoicing via FacturAPI)
# FACTURAPI_API_KEY=                       # FacturAPI platform API key
# CFDI_INVOICE_LINK_EXPIRY_HOURS=72        # Default token expiry for self-service links

# Mercado Pago Point (optional — enables terminal payments, Pro+ only)
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_INTEGRATOR_ID=
MP_WEBHOOK_SECRET=                       # Webhook signing secret from MP dashboard (validates x-signature)
BASE_URL=https://pos.desktop.kitchen

# Open Banking (optional — enables bank account connections)
# BELVO_SECRET_ID=                       # Belvo API secret ID
# BELVO_SECRET_PASSWORD=                 # Belvo API secret password
# BELVO_API_URL=https://sandbox.belvo.com
BELVO_WEBHOOK_SECRET=                    # HMAC-SHA256 secret for Belvo webhook signature verification

# Capacitor / iOS (set these in .env.ios, not here)
# VITE_API_URL=http://192.168.1.100:3001/api
# VITE_API_URL_FALLBACKS=http://192.168.0.100:3001/api,http://10.0.0.100:3001/api
